{
	"extends": "./jsconfig.json",
	"compilerOptions": {
		"allowJs": true,
		"checkJs": true,
		"strict": true,
		"noUnusedLocals": true,
		"noUnusedParameters": true,
		"noImplicitReturns": true
	},
	"include": ["src/**/*.ts", "src/**/*.svelte", "src/**/*.js"],
	"exclude": ["node_modules", "dist", "build", "**/*.test.ts"]
}
