{
  "extends": "./.svelte-kit/tsconfig.json",
  "compilerOptions": {
    "allowJs": true,
    "checkJs": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "sourceMap": true,
    "strict": true,
    "moduleResolution": "bundler",
    "paths": {
      "$lib": ["./src/lib"],
      "$lib/*": ["./src/lib/*"],
      "@mosiri/shared": ["../../packages/shared/src"],
      "@mosiri/shared/*": ["../../packages/shared/src/*"],
      "@mosiri/ui": ["../../packages/ui/src"],
      "@mosiri/ui/*": ["../../packages/ui/src/*"],
      "@mosiri/aws-client": ["../../packages/aws-client/src"],
      "@mosiri/aws-client/*": ["../../packages/aws-client/src/*"]
    }
  },
  "include": ["src/**/*.js", "src/**/*.ts", "src/**/*.svelte"]
}