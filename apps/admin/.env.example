# Base Path Configuration
# Leave empty for local development, set to /admin for production
BASE_PATH=

# AWS Configuration
PUBLIC_AWS_REGION=ap-northeast-1
PUBLIC_AWS_COGNITO_USER_POOL_ID=
PUBLIC_AWS_COGNITO_CLIENT_ID=
PUBLIC_AWS_S3_BUCKET_NAME=

# API Configuration
PUBLIC_API_ENDPOINT=
PUBLIC_API_KEY=

# DynamoDB Tables
PUBLIC_DYNAMODB_PRESET_INFO_TABLE=preset_info
PUBLIC_DYNAMODB_SIMULATION_RESERVE_TABLE=simulation_reserve
PUBLIC_DYNAMODB_VIEWER_INFO_TABLE=viewer_info

# Feature Flags
PUBLIC_ENABLE_NARROW_SIMULATION=true