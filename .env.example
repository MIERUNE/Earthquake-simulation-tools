# Cognito Configuration
VITE_COGNITO_REGION=ap-northeast-1
VITE_COGNITO_USER_POOL_ID=your-user-pool-id
VITE_COGNITO_CLIENT_ID=your-client-id
VITE_COGNITO_IDENTITY_POOL_ID=your-identity-pool-id

# AWS Configuration
AWS_REGION=ap-northeast-1
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key

# S3 Configuration
S3_BUCKET_NAME=your-s3-bucket-name

# Batch Job Configuration - Narrow Simulation
NARROW_JOBNAME=narrow-sim-job
NARROW_JOBQUEUE=SimNarrowBatchJQue
NARROW_JOBDEFINITION=SimNarrowBatchJobDef

# Batch Job Configuration - Wide Simulation
WIDE_JOBNAME=wide-sim-job
WIDE_JOBQUEUE=SimWideBatchJQue
WIDE_JOBDEFINITION=SimWideBatchJobDef

# Wide Simulation S3 Bucket (for result storage)
WIDE_SIMULATION_S3_BUCKET=your-wide-simulation-s3-bucket

# DPP Configuration (for simulation job registration)
DPP_S3_ROLE_ARN=arn:aws:iam::YOUR_ACCOUNT_ID:role/your-role-name
DPP_S3_BUCKET_NAME=your-dpp-s3-bucket-name

# Webhook Configuration
VITE_SIMULATION_WEBHOOK_API_KEY=your-webhook-api-key

# Mode Configuration (development/docker/production)
MODE=development
VITE_MODE=development